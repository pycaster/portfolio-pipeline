# ClickHouse connection
CH_ADDR=localhost:9000
CH_HTTP=localhost:18123
CH_DB=portfolio
CH_USER=default
CH_PASS=changeme

# Path to broker CSV uploads directory
# Structure: uploads/{broker}/date-range.csv
# e.g.       uploads/robinhood/2026-01-01_2026-02-27.csv
UPLOADS=./uploads

# Watchlist: symbols to always track signals for, even without an open position.
# Comma-separated. MAG7 + high-conviction names.
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,AMD,PLTR,RKLB,ASTS,IREN,NOW,SOFI,HOOD,MU

# Claude API for make gen-insights
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
CLAUDE_MODEL=claude-opus-4-6
